{
    "name": "evulery/pro",
    "description": "Sistema Prenotazioni Ristorante SaaS",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "stripe/stripe-php": "^14.0",
        "phpmailer/phpmailer": "^7.0",
        "minishlink/web-push": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/functions.php",
            "app/Helpers/view.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "classmap-authoritative": true,
        "sort-packages": true
    }
}
