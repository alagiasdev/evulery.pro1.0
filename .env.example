APP_NAME=Evulery
APP_URL=https://tuodominio.com
APP_DEBUG=false
APP_TIMEZONE=Europe/Rome

DB_HOST=localhost
DB_PORT=3306
DB_NAME=evulery_pro
DB_USER=
DB_PASS=

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Encryption key per chiavi Stripe tenant (openssl rand -base64 32)
APP_ENCRYPTION_KEY=

MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM=noreply@tuodominio.com
MAIL_FROM_NAME=Evulery

# TurboSMTP - Email broadcast massivo (separato da MAIL_* transazionale)
BROADCAST_SMTP_HOST=pro.turbo-smtp.com
BROADCAST_SMTP_PORT=587
BROADCAST_SMTP_USERNAME=
BROADCAST_SMTP_PASSWORD=
BROADCAST_SMTP_ENCRYPTION=tls
BROADCAST_SMTP_FROM=noreply@tuodominio.com
BROADCAST_SMTP_FROM_NAME=Evulery

# reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# VAPID Keys per Web Push (generare con: vendor/bin/generate-vapid-keys)
VAPID_SUBJECT=mailto:notifiche@evulery.it
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Email supporto e telefono
SUPPORT_EMAIL=info@evulery.it
SUPPORT_PHONE=

# Performance monitoring: logga in storage/logs/perf-YYYY-MM-DD.log le request
# con durata >= threshold (ms). Mettere PERF_LOG_ENABLED=0 o THRESHOLD=0 per disabilitare.
PERF_LOG_ENABLED=1
PERF_LOG_THRESHOLD_MS=500

# Target CNAME per i domini personalizzati dei tenant Enterprise.
# Se non impostato, fallback all'host estratto da APP_URL.
CUSTOM_DOMAIN_CNAME_TARGET=dash.evulery.it
# Target A record (IP del VPS) — usato quando il tenant non puo mettere
# un CNAME (dominio apex o registrar che lo blocca). Se non impostato,
# viene risolto automaticamente dal CNAME target (cached 24h).
CUSTOM_DOMAIN_A_TARGET=46.16.90.48
